    "@intake/types": "workspace:*",
    "@intake/ui": "workspace:*",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@neondatabase/auth": "0.4.1-beta",
    "@neondatabase/serverless": "^1.1.0",
    "@octokit/rest": "^22.0.1",
    "@tanstack/react-query": "^5.101.2",
    "client-only": "^0.0.1",
    "date-fns": "^4.4.0",
    "dexie": "^4.4.4",
    "dexie-react-hooks": "^4.4.0",
