# ============================================================
# Environment Variable Security Policy
# ============================================================
# NEXT_PUBLIC_* vars are compiled into the CLIENT bundle (public, safe for browser)
# All other vars are SERVER-ONLY secrets (never exposed to client)
#
# Public (client-safe):
#   NEXT_PUBLIC_APP_VERSION        - App version display
#
# Server-only secrets (NEVER prefix with NEXT_PUBLIC_):
#   ANTHROPIC_API_KEY              - Server-side fallback Anthropic key (used only for ALLOWED_EMAILS users)
#   GROQ_API_KEY                   - Server-side fallback Groq key (used only for ALLOWED_EMAILS users)
#   ALLOWED_EMAILS                 - Auth whitelist + env-var key access list
#   API_KEY_ENCRYPTION_SECRET      - 32 bytes (base64) — encrypts user-provided keys at rest
#   DATABASE_URL                   - NeonDB connection string (Neon Auth + push tables)
#   BETTER_AUTH_SECRET             - Neon Auth session secret (openssl rand -base64 32)
#   BETTER_AUTH_URL                - Public URL of the deployed app
#   PGPASSWORD                     - Database password
#   GITHUB_TOKEN                   - Fine-grained PAT (Issues: read/write) — files in-app bug reports
# ============================================================

# Neon Auth (replaces Privy as of phase 41)
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# Anthropic (Claude AI) — server-side fallback only; non-whitelisted users
# must provide their own key in Settings → AI features.
ANTHROPIC_API_KEY=sk-ant-xxx

# Groq (voice transcription) — same: server fallback for ALLOWED_EMAILS only.
GROQ_API_KEY=gsk_xxx

# Whitelist: who can sign in, AND who is allowed to use the server-side
# fallback API keys above. Anyone else who signs in must supply their own
# key (or use a key shared with them by another user).
ALLOWED_EMAILS=you@gmail.com

# 32 random bytes (base64) — encrypts user-supplied API keys at rest in
# Neon. Generate with: openssl rand -base64 32
# Rotating this value invalidates every stored key (users re-enter).
API_KEY_ENCRYPTION_SECRET=generate-with-openssl-rand-base64-32

# GitHub — powers the in-app bug reporter (Settings → Report a Bug) and the
# label setup script. Use a fine-grained PAT scoped to this repo only, with
# the single permission "Issues: read and write". Without it the reporter is
# inert (the form still works; submission fails with a clear message).
GITHUB_TOKEN=github_pat_xxx
# Target repo for filed issues (owner/name). Defaults to RyRy79261/intake-tracker.
GITHUB_REPO=RyRy79261/intake-tracker

# Recommended for most uses
DATABASE_URL=postgresql://neondb_owner:.../neondb?sslmode=require

# For uses requiring a connection without pgbouncer
DATABASE_URL_UNPOOLED=postgresql://neondb_owner:.../neondb?sslmode=require

# Parameters for constructing your own connection string
PGHOST=...
PGHOST_UNPOOLED=...
PGUSER=neondb_owner
PGDATABASE=neondb
PGPASSWORD=...

# Parameters for Vercel Postgres Templates
POSTGRES_URL=postgresql://neondb_owner:.../neondb?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://neondb_owner:.../neondb?sslmode=require
POSTGRES_USER=neondb_owner
POSTGRES_HOST=...
POSTGRES_PASSWORD=...
POSTGRES_DATABASE=neondb
POSTGRES_URL_NO_SSL=postgresql://neondb_owner:.../neondb
POSTGRES_PRISMA_URL=postgresql://neondb_owner:.../neondb?connect_timeout=15&sslmode=require

# E2E Test Credentials (Neon Auth) — used by Playwright global-setup to seed a session
# These are NOT secrets; they only work with your dev/staging Neon Auth instance
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=

# MCP custom-connector for claude.ai (see docs/mcp-connector.md).
# OPTIONAL. If unset, the OAuth metadata endpoints derive the public origin
# from VERCEL_URL or X-Forwarded-* headers. Set this explicitly when running
# behind a proxy that doesn't forward those headers, or to pin the issuer
# to a specific domain. Must be the public HTTPS URL with no trailing slash.
MCP_PUBLIC_URL=
