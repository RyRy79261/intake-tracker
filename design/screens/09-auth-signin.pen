                  "fontSize": 13
                },
                {
                  "type": "frame",
                  "id": "Xbkti",
                  "name": "rightLine",
                  "width": "fill_container",
                  "height": 1,
                  "fill": "$border-default"
                }
              ]
            },
            {
              "type": "frame",
              "id": "595nk",
              "name": "googleBtn",
              "width": "fill_container",
              "height": 44,
              "fill": "$bg-card",
              "cornerRadius": 8,
              "stroke": {
                "align": "inside",
                "thickness": 1,
                "fill": "$border-input"
              },
              "gap": 10,
              "justifyContent": "center",
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "iyMZo",
                  "name": "googleG",
                  "fill": "$text-heading",
                  "content": "G",
                  "fontFamily": "Outfit",
                  "fontSize": 18,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "M7B6t",
                  "name": "googleText",
                  "fill": "$text-heading",
                  "content": "Continue with Google",
                  "fontFamily": "Outfit",
                  "fontSize": 14,
                  "fontWeight": "500"
                }
              ]
            },
            {
              "type": "frame",
              "id": "OTT1H",
              "name": "signupRow",
              "gap": 4,
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
