{
  "version": "2.11",
  "children": [
    {
      "type": "frame",
      "id": "1Na6U",
      "x": 0,
      "y": 0,
      "name": "Sign In",
      "width": 440,
      "height": 932,
      "fill": "$bg-page",
      "layout": "vertical",
      "gap": 12,
      "padding": [
        180,
        24,
        0,
        24
      ],
      "alignItems": "center",
      "children": [
        {
          "type": "frame",
          "id": "PS1AL",
          "name": "backRow",
          "gap": 8,
          "alignItems": "center",
          "children": [
            {
              "type": "icon_font",
              "id": "ZCWq3",
              "name": "backIcon",
              "width": 20,
              "height": 20,
              "iconFontName": "arrow-left",
              "iconFontFamily": "lucide",
              "fill": "$text-muted"
            },
            {
              "type": "text",
              "id": "YFgVf",
              "name": "backText",
              "fill": "$text-muted",
              "content": "Back",
              "fontFamily": "Outfit",
              "fontSize": 14,
              "fontWeight": "500"
            }
          ]
        },
        {
          "type": "frame",
          "id": "BvpEY",
          "name": "Auth Card",
          "width": "fill_container",
          "fill": "$bg-card",
          "cornerRadius": 12,
          "effect": {
            "type": "shadow",
            "shadowType": "outer",
            "color": "#0F172A10",
            "offset": {
              "x": 0,
              "y": 2
            },
            "blur": 12
          },
          "layout": "vertical",
          "gap": 20,
          "padding": [
            32,
            32,
            28,
            32
          ],
          "alignItems": "center",
          "children": [
            {
              "type": "frame",
              "id": "kpE0i",
              "name": "headerGroup",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 8,
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "QvpXP",
                  "name": "heading",
                  "fill": "$text-heading",
                  "content": "Welcome back",
                  "fontFamily": "Outfit",
                  "fontSize": 28,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "bKbGU",
                  "name": "subtitle",
                  "fill": "$text-muted",
                  "content": "Sign in to your Intake Tracker account",
                  "textAlign": "center",
                  "fontFamily": "Outfit",
                  "fontSize": 14
                }
              ]
            },
            {
              "type": "frame",
              "id": "VdyyA",
              "name": "emailGroup",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 6,
              "children": [
                {
                  "type": "text",
                  "id": "FpZkh",
                  "name": "emailLabel",
                  "fill": "$text-heading",
                  "content": "Email",
                  "fontFamily": "Outfit",
                  "fontSize": 14,
                  "fontWeight": "500"
                },
                {
                  "type": "frame",
                  "id": "77NgR",
                  "name": "emailInput",
                  "width": "fill_container",
                  "height": 44,
                  "fill": "$bg-input",
                  "cornerRadius": 8,
                  "stroke": {
                    "align": "inside",
                    "thickness": 1,
                    "fill": "$border-input"
                  },
                  "padding": [
                    0,
                    16
                  ],
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "text",
                      "id": "LXE1w",
                      "name": "emailPlaceholder",
                      "fill": "$text-placeholder",
                      "content": "you@example.com",
                      "fontFamily": "Outfit",
                      "fontSize": 14
                    }
                  ]
                }
              ]
            },
            {
              "type": "frame",
              "id": "dgrJ9",
              "name": "passGroup",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 6,
              "children": [
                {
                  "type": "frame",
                  "id": "hKgra",
                  "name": "passLabelRow",
                  "width": "fill_container",
                  "justifyContent": "space_between",
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "text",
                      "id": "Tu4iE",
                      "name": "passLabel",
                      "fill": "$text-heading",
                      "content": "Password",
                      "fontFamily": "Outfit",
                      "fontSize": 14,
                      "fontWeight": "500"
                    },
                    {
                      "type": "text",
                      "id": "k4zeU",
                      "name": "forgotLink",
                      "fill": "$text-link",
                      "content": "Forgot your password?",
                      "fontFamily": "Outfit",
                      "fontSize": 13,
                      "fontWeight": "500"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "kUdej",
                  "name": "passInput",
                  "width": "fill_container",
                  "height": 44,
                  "fill": "$bg-input",
                  "cornerRadius": 8,
                  "stroke": {
                    "align": "inside",
                    "thickness": 1,
                    "fill": "$border-input"
                  },
                  "padding": [
                    0,
                    16
                  ],
                  "justifyContent": "end",
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "icon_font",
                      "id": "YWj0v",
                      "name": "eyeIcon",
                      "width": 18,
                      "height": 18,
                      "iconFontName": "eye-off",
                      "iconFontFamily": "lucide",
                      "fill": "$text-placeholder"
                    }
                  ]
                }
              ]
            },
            {
              "type": "frame",
              "id": "RPhhg",
              "name": "signInBtn",
              "width": "fill_container",
              "height": 44,
