              "cornerRadius": 8,
              "justifyContent": "center",
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "F8ap9",
                  "name": "signInText",
                  "fill": "$primary-text",
                  "content": "Sign In",
                  "fontFamily": "Outfit",
                  "fontSize": 15,
                  "fontWeight": "600"
                }
              ]
            },
            {
              "type": "frame",
              "id": "3wV4c",
              "name": "dividerRow",
              "width": "fill_container",
              "gap": 12,
              "alignItems": "center",
              "children": [
                {
                  "type": "frame",
                  "id": "4Zy8A",
                  "name": "leftLine",
