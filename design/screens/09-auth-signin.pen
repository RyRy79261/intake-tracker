                },
                {
                  "type": "text",
                  "id": "OTszZ",
                  "name": "signupLink",
                  "fill": "$text-link",
                  "content": "Sign up",
                  "fontFamily": "Outfit",
                  "fontSize": 14,
                  "fontWeight": "600"
                }
              ]
            }
          ]
        },
        {
          "type": "text",
          "id": "pT5Jc",
          "name": "footerText",
          "fill": "$text-placeholder",
          "textGrowth": "fixed-width",
          "width": 340,
          "content": "Your health data stays on your device. Sign in lets you sync across devices.",
          "textAlign": "center",
          "fontFamily": "Outfit",
          "fontSize": 13
        }
      ]
    }
  ],
  "variables": {
    "bg-card": {
      "type": "color",
      "value": "#FFFFFF"
    },
    "bg-input": {
      "type": "color",
      "value": "#F8FAFC"
    },
    "bg-page": {
      "type": "color",
      "value": "#F1F5F9"
    },
    "border-default": {
      "type": "color",
      "value": "#E2E8F0"
    },
    "border-input": {
      "type": "color",
      "value": "#E2E8F0"
    },
    "primary": {
      "type": "color",
      "value": "#3B82F6"
    },
    "primary-text": {
      "type": "color",
      "value": "#FFFFFF"
    },
    "text-body": {
      "type": "color",
      "value": "#475569"
    },
    "text-heading": {
      "type": "color",
      "value": "#1E293B"
    },
    "text-link": {
      "type": "color",
      "value": "#3B82F6"
    },
    "text-muted": {
      "type": "color",
      "value": "#64748B"
    },
    "text-placeholder": {
      "type": "color",
      "value": "#94A3B8"
    }
