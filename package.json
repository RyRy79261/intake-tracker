{
  "name": "intake-tracker",
  "version": "1.32.0",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "next dev",
    "build": "if [ -n \"$CAPACITOR_BUILD\" ]; then node scripts/cap-build.js; else next build; fi",
    "build:cap": "CAPACITOR_BUILD=1 node scripts/cap-build.js",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "vercel-build": "pnpm db:migrate && next build",
    "start": "next start",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:tz:sa": "TZ=Africa/Johannesburg vitest run",
    "test:tz:de": "TZ=Europe/Berlin vitest run",
    "test:tz": "pnpm test:tz:sa && pnpm test:tz:de",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:mutation": "stryker run",
    "bench": "vitest bench",
    "bench:ci": "vitest bench --outputJson benchmarks/results.json && node -e \"const f='benchmarks/results.json';const d=JSON.parse(require('fs').readFileSync(f,'utf8'));d.files.forEach(e=>{e.filepath=e.filepath.replace(process.cwd()+'/','')});require('fs').writeFileSync(f,JSON.stringify(d,null,2)+'\\n')\"",
    "seed:dev": "tsx scripts/seed-dev-db.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:reset": "tsx scripts/reset-neon-db.ts",
    "db:truncate-push": "tsx scripts/truncate-push-tables.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/local-notifications": "^8.1.0",
    "@capacitor/network": "^8.0.1",
    "@modelcontextprotocol/sdk": "1.26.0",
    "@neondatabase/auth": "0.2.0-beta.1",
    "@neondatabase/serverless": "^1.0.2",
    "@octokit/rest": "^22.0.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@tanstack/react-query": "^5.90.20",
    "class-variance-authority": "^0.7.0",
    "client-only": "^0.0.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.0.8",
    "dexie-react-hooks": "^1.1.7",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.454.0",
    "mcp-handler": "^1.1.0",
    "motion": "^12.29.2",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "2.15.4",
    "server-only": "^0.0.1",
    "simple-statistics": "^7.8.8",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "web-push": "^3.6.7",
    "zod": "3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "10.0.1",
    "@next/env": "16.2.6",
    "@next/eslint-plugin-next": "16.2.7",
    "@playwright/test": "^1.58.2",
    "@serwist/turbopack": "^9.5.11",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testcontainers/postgresql": "^11.14.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.8.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "axe-core": "^4.11.4",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "eslint-config-next": "16.2.7",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^4.8.0",
    "globals": "17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "pg": "^8.20.0",
    "postcss": "^8.5.12",
    "serwist": "^9.5.11",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.60.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  }
}
