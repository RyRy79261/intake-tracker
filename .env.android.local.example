# Copy this to .env.android.local and fill in the values for the Android build.
# Both files are gitignored. scripts/build-android.sh sources .env.android.local
# automatically before running `next build`.

# Origin where /api/* is hosted (e.g. your Vercel deploy URL, no trailing slash).
# Required for AI features (Claude parsing, medicine search, interaction checks)
# and push subscription endpoints to work when the device is online. When the
# device is offline these calls fail and the app degrades gracefully.
# Leave unset/blank for a fully offline-only APK with no AI features.
NEXT_PUBLIC_API_BASE_URL=https://your-deploy.vercel.app

# Leave UNSET for the Android build. Privy's embedded auth iframe doesn't
# whitelist the capacitor:// origin, so providers.tsx will fall back to its
# no-auth path when this is missing — which is what we want for a personal
# offline build.
# NEXT_PUBLIC_PRIVY_APP_ID=
