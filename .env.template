# ============================================================
# Environment Variable Security Policy
# ============================================================
# NEXT_PUBLIC_* vars are compiled into the CLIENT bundle (public, safe for browser)
# All other vars are SERVER-ONLY secrets (never exposed to client)
#
# Public (client-safe):
#   NEXT_PUBLIC_PRIVY_APP_ID       - Privy app identifier (public by design)
#   NEXT_PUBLIC_PRIVY_CLIENT_ID    - Privy client identifier (public by design)
#   NEXT_PUBLIC_LOCAL_AGENT_MODE   - E2E test bypass (ignored in production)
#   NEXT_PUBLIC_APP_VERSION        - App version display
#
# Server-only secrets (NEVER prefix with NEXT_PUBLIC_):
#   PRIVY_APP_SECRET               - Privy server auth secret
#   PERPLEXITY_API_KEY             - Perplexity AI API key
#   ALLOWED_EMAILS                 - Auth whitelist
#   DATABASE_URL                   - NeonDB connection string
#   PGPASSWORD                     - Database password
# ============================================================

# Privy
NEXT_PUBLIC_PRIVY_APP_ID=your-app-id
NEXT_PUBLIC_PRIVY_CLIENT_ID=your-client-id
PRIVY_APP_SECRET=your-app-secret

# Perplexity
PERPLEXITY_API_KEY=pplx-xxx

# Whitelist (your email)
ALLOWED_EMAILS=you@gmail.com

# Recommended for most uses
DATABASE_URL=postgresql://neondb_owner:.../neondb?sslmode=require

# For uses requiring a connection without pgbouncer
DATABASE_URL_UNPOOLED=postgresql://neondb_owner:.../neondb?sslmode=require

# Parameters for constructing your own connection string
PGHOST=...
PGHOST_UNPOOLED=...
PGUSER=neondb_owner
PGDATABASE=neondb
PGPASSWORD=...

# Parameters for Vercel Postgres Templates
POSTGRES_URL=postgresql://neondb_owner:.../neondb?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://neondb_owner:.../neondb?sslmode=require
POSTGRES_USER=neondb_owner
POSTGRES_HOST=...
POSTGRES_PASSWORD=...
POSTGRES_DATABASE=neondb
POSTGRES_URL_NO_SSL=postgresql://neondb_owner:.../neondb
POSTGRES_PRISMA_URL=postgresql://neondb_owner:.../neondb?connect_timeout=15&sslmode=require